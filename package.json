{
    "name": "laravel-goto-controller",
    "displayName": "Laravel Goto Controller",
    "description": "Quick jump to controller",
    "version": "1.0.1",
    "publisher": "ctf0",
    "engines": {
        "vscode": "^1.110.0"
    },
    "enabledApiProposals": [
        "editorHoverVerbosityLevel"
    ],
    "repository": "https://github.com/ctf0/laravel-goto-controller",
    "icon": "images/logo.png",
    "categories": [
        "Other"
    ],
    "keywords": [
        "PHP",
        "Laravel",
        "goto",
        "file navigation"
    ],
    "activationEvents": [
        "workspaceContains:composer.json",
        "onLanguage:php",
        "onLanguage:blade",
        "workspaceContains:artisan",
        "onCommand:lgc.showMiddleware"
    ],
    "main": "./out/main",
    "contributes": {
        "commands": [
            {
                "command": "lgc.addAppUrl",
                "title": "Add App Url",
                "category": "Laravel GoTo Controller"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Laravel Goto Controller",
            "properties": {
                "laravelGotoController.classmap_file": {
                    "type": "string",
                    "default": "vendor/composer/autoload_classmap.php",
                    "description": "Path to Composer's autoload_classmap.php, relative to the workspace root"
                },
                "laravelGotoController.phpCommand": {
                    "type": "string",
                    "default": "php",
                    "description": "PHP command used to load routes and the Composer classmap"
                },
                "laravelGotoController.routeListCommand": {
                    "type": "string",
                    "default": "artisan route:list --except-vendor --json",
                    "description": "Command appended to phpCommand to output the Laravel route list as JSON"
                },
                "laravelGotoController.displayMode": {
                    "type": "integer",
                    "enum": [
                        0,
                        1,
                        2
                    ],
                    "enumDescriptions": [
                        "none: Disable CodeLens and line decorations",
                        "codeLens: Show route metadata as clickable CodeLenses",
                        "lineDecoration: Show route metadata as a line decoration before the method"
                    ],
                    "default": 1,
                    "description": "How route metadata is displayed above controller methods"
                },
                "laravelGotoController.expandHoverVerbosity": {
                    "type": "boolean",
                    "default": true,
                    "description": "Expand route metadata in the hover verbosity panel by default"
                },
                "laravelGotoController.showMiddlewarePath": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show middleware file paths in the picker"
                },
                "laravelGotoController.routeCopyPrefix": {
                    "type": "string",
                    "default": "@",
                    "example": "route('@')",
                    "description": "Prefix added when copying route names from the code lens. The '@' will be replaced with the route name"
                },
                "laravelGotoController.removeNamePrefix": {
                    "type": "array",
                    "default": [],
                    "items": {
                        "type": "string"
                    },
                    "description": "Prefixes to remove from route names when displaying route metadata"
                },
                "laravelGotoController.dockerVolumePath": {
                    "type": "string",
                    "default": null,
                    "example": "/var/www/html",
                    "description": "Container path mapped to the workspace root when PHP runs in Docker"
                },
                "laravelGotoController.appUrl": {
                    "type": "string",
                    "default": null,
                    "examples": [
                        "http://localhost",
                        "http://127.0.0.1"
                    ],
                    "description": "Base URL used when opening a route; the route URI is appended to it"
                },
                "laravelGotoController.lineDecorationStyles": {
                    "type": "string",
                    "default": "font-size: small; opacity: 0.5",
                    "markdownDescription": "line decoration styles, `#laravelGotoController.displayMode#` must be `2`"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run esbuild-base -- --pure:console.log --minify",
        "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
        "esbuild": "npm run esbuild-base -- --sourcemap",
        "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
        "watch": "npm run esbuild"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/vscode": "^1.110.0",
        "@vscode/dts": "^0.4.1",
        "esbuild": "^0.28.1",
        "typescript": "^7.0.2"
    },
    "dependencies": {
        "execa": "^9.6.1",
        "php-parser": "^3.7.0"
    }
}
